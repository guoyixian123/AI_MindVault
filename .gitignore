# 忽略 IDEA 配置
.idea/

# 忽略环境变量文件（包含密钥）
.env
**/.env

# 忽略 Maven 编译输出（递归所有模块的 target 目录）
target/
AI_mindVault/

# 忽略包含敏感信息的配置文件
application.yml
**/application.yml

# 忽略其他文件
.uploads/
*/.mvn/
*.json
*.iml
*.DS_Store
**/test/

# 不忽略前端的 package 文件
!**/package.json
!**/package-lock.json

# 不忽略配置模板
!application.yml.example